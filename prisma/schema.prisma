// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  recipes  Recipe[]

  @@map("users")
}

model Recipe {
  slug         String   @id
  title        String
  shortDesc    String
  fullDesc     String
  image        String?
  servings     Int
  cookTime     Int
  instructions String[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  sauses      Filling[]            @relation("RecipeSauses")
  filling     Filling[]            @relation("RecipeFilling")
  ingredients IngredientRelation[]

  @@map("recipes")
}

model Ingredient {
  id    Int    @id @default(autoincrement())
  title String
  count String
  unit  String

  recipeIngredients  IngredientRelation[]
  fillingIngredients IngredientRelationFilling[]

  @@map("ingredients")
}

model Filling {
  id          Int    @id @default(autoincrement())
  title       String
  description String

  recipeSauses  Recipe[]                    @relation("RecipeSauses")
  recipeFilling Recipe[]                    @relation("RecipeFilling")
  ingredients   IngredientRelationFilling[]

  @@map("fillings")
}

model IngredientRelation {
  id           Int    @id @default(autoincrement())
  recipeId     String
  ingredientId Int
  index        Int    @default(0)

  recipe     Recipe     @relation(fields: [recipeId], references: [slug], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@map("recipe_ingredients")
}

model IngredientRelationFilling {
  id           Int @id @default(autoincrement())
  fillingId    Int
  ingredientId Int
  index        Int @default(0)

  filling    Filling    @relation(fields: [fillingId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([fillingId, ingredientId])
  @@map("filling_ingredients")
}
